<% layout("/layouts/boilerplate.ejs") %>

<style>
  .show-container {
    max-width: 900px;
    margin: 40px auto;
    padding: 0 20px;
  }

  .listing-title {
    font-size: 2rem;
    font-weight: 700;
    color: #222;
    margin-bottom: 16px;
  }

  .listing-hero-img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    border-radius: 16px;
    margin-bottom: 24px;
  }

  .listing-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 20px;
  }

  .meta-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #f5f5f5;
    border-radius: 20px;
    padding: 6px 14px;
    font-size: 0.9rem;
    color: #444;
    font-weight: 500;
  }

  .meta-badge i {
    color: #888;
  }

  .listing-price {
    font-size: 1.5rem;
    font-weight: 700;
    color: #222;
    margin-bottom: 20px;
  }

  .listing-price span {
    font-size: 1rem;
    font-weight: 400;
    color: #666;
  }

  .listing-description {
    font-size: 1rem;
    color: #555;
    line-height: 1.7;
    margin-bottom: 28px;
    padding-bottom: 28px;
    border-bottom: 1px solid #e0e0e0;
  }

  .action-btns {
    display: flex;
    gap: 12px;
    margin-bottom: 40px;
  }

  .btn-edit {
    padding: 10px 28px;
    border-radius: 8px;
    border: 1.5px solid #222;
    background: white;
    color: #222;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    text-decoration: none;
  }

  .btn-edit:hover {
    background: #222;
    color: white;
  }

  .btn-delete {
    padding: 10px 28px;
    border-radius: 8px;
    border: none;
    background: #ff385c;
    color: white;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.2s;
  }

  .btn-delete:hover {
    background: #e0002f;
  }

  /* Reviews Section */
  .section-title {
    font-size: 1.4rem;
    font-weight: 700;
    color: #222;
    margin-bottom: 20px;
  }

  .review-form-card {
    background: #fafafa;
    border: 1px solid #ebebeb;
    border-radius: 16px;
    padding: 28px;
    margin-bottom: 36px;
  }

  .review-form-card label {
    font-weight: 600;
    color: #333;
    font-size: 0.9rem;
    margin-bottom: 6px;
    display: block;
  }

  .review-form-card textarea {
    border-radius: 10px;
    border: 1.5px solid #ddd;
    padding: 12px;
    font-size: 0.95rem;
    resize: none;
    transition: border-color 0.2s;
  }

  .review-form-card textarea:focus {
    border-color: #222;
    box-shadow: none;
    outline: none;
  }

  .rating-display {
    font-weight: 700;
    color: #222;
    font-size: 1rem;
    margin-left: 8px;
  }

  .btn-submit-review {
    background: #222;
    color: white;
    border: none;
    padding: 10px 28px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.2s;
  }

  .btn-submit-review:hover {
    background: #444;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
    margin-top: 16px;
  }

  .review-card {
    background: white;
    border: 1px solid #ebebeb;
    border-radius: 14px;
    padding: 20px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    transition: box-shadow 0.2s;
    position: relative;
  }

  .review-card:hover {
    box-shadow: 0 6px 20px rgba(0,0,0,0.1);
  }

  .reviewer-name {
    font-weight: 700;
    font-size: 0.95rem;
    color: #222;
    margin-bottom: 6px;
  }

  .review-stars {
    color: #ff385c;
    font-size: 0.85rem;
    margin-bottom: 10px;
    letter-spacing: 1px;
  }

  .review-comment {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.5;
    margin-bottom: 14px;
  }

  .btn-delete-review {
    background: none;
    border: 1px solid #ddd;
    border-radius: 6px;
    padding: 4px 12px;
    font-size: 0.8rem;
    color: #888;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-delete-review:hover {
    border-color: #ff385c;
    color: #ff385c;
  }

  .host-bar {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 20px;
  padding: 16px 20px;
  background: #f9f9f9;
  border-radius: 14px;
  border: 1px solid #ebebeb;
}

.host-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff385c, #ff6b81);
  color: white;
  font-size: 1.3rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.host-info {
  display: flex;
  flex-direction: column;
}

.host-label {
  font-size: 0.78rem;
  color: #888;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.host-name {
  font-size: 1rem;
  font-weight: 700;
  color: #222;
  text-transform: capitalize;
}

/* ═══ Show Page Responsive ═══ */

/* ── Tablet (≤ 768px) ── */
@media (max-width: 768px) {
  .show-container {
    margin: 24px auto;
    padding: 0 16px;
  }

  .listing-title {
    font-size: 1.6rem;
    margin-bottom: 12px;
  }

  .listing-hero-img {
    height: 300px;
    border-radius: 12px;
    margin-bottom: 18px;
  }

  .listing-meta {
    gap: 8px;
  }

  .meta-badge {
    padding: 5px 12px;
    font-size: 0.85rem;
  }

  .listing-price {
    font-size: 1.3rem;
  }

  .action-btns {
    flex-wrap: wrap;
    gap: 10px;
  }

  .btn-edit, .btn-delete {
    padding: 9px 22px;
    font-size: 0.9rem;
  }

  .reviews-grid {
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
  }

  .review-form-card {
    padding: 20px;
  }

  .host-bar {
    padding: 14px 16px;
    gap: 12px;
  }

  .host-avatar {
    width: 42px;
    height: 42px;
    font-size: 1.1rem;
  }

  #map {
    height: 300px !important;
    border-radius: 10px !important;
  }
}

/* ── Small phones (≤ 480px) ── */
@media (max-width: 480px) {
  .show-container {
    margin: 16px auto;
    padding: 0 10px;
  }

  .listing-title {
    font-size: 1.35rem;
    margin-bottom: 10px;
  }

  .listing-hero-img {
    height: 220px;
    border-radius: 10px;
    margin-bottom: 14px;
  }

  .listing-meta {
    flex-direction: column;
    gap: 6px;
  }

  .listing-price {
    font-size: 1.15rem;
    margin-bottom: 14px;
  }

  .listing-description {
    font-size: 0.92rem;
    margin-bottom: 20px;
    padding-bottom: 20px;
  }

  .action-btns {
    flex-direction: column;
    gap: 8px;
    margin-bottom: 28px;
  }

  .btn-edit, .btn-delete {
    width: 100%;
    text-align: center;
    padding: 12px 20px;
  }

  .section-title {
    font-size: 1.15rem;
    margin-bottom: 14px;
  }

  .review-form-card {
    padding: 16px;
    border-radius: 12px;
    margin-bottom: 24px;
  }

  .reviews-grid {
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .review-card {
    padding: 16px;
    border-radius: 10px;
  }

  .host-bar {
    padding: 12px 14px;
    gap: 10px;
    border-radius: 10px;
  }

  .host-avatar {
    width: 38px;
    height: 38px;
    font-size: 1rem;
  }

  .host-label {
    font-size: 0.72rem;
  }

  .host-name {
    font-size: 0.9rem;
  }

  h3 {
    font-size: 1.2rem;
  }

  #map {
    height: 250px !important;
    border-radius: 8px !important;
    margin-top: 14px !important;
  }
}
</style>

<div class="show-container">



  <!-- Title -->
  <h1 class="listing-title"><%= listing.title %></h1>

  <!-- Hero Image -->
  <img src="<%= listing.image?.url || 'https://images.unsplash.com/photo-1552733407-5d5c46c3bb3b?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=60' %>" class="listing-hero-img" alt="<%= listing.title %>">

    <!--Username-->
  <div class="host-bar">
  <div class="host-avatar">
    <%= listing.owner?.username?.charAt(0)?.toUpperCase() || 'A' %>
  </div>
  <div class="host-info">
    <span class="host-label">Hosted by</span>
    <span class="host-name"><%= listing.owner?.username || "Anonymous" %></span>
  </div>
</div>
  <!-- Meta Badges -->
  <div class="listing-meta">
    <span class="meta-badge"><i class="fa-solid fa-location-dot"></i> <%= listing.location %></span>
    <span class="meta-badge"><i class="fa-solid fa-earth-americas"></i> <%= listing.country %></span>
  </div>

  <!-- Price -->
  <div class="listing-price">
    &#8377; <%= listing.price.toLocaleString("en-IN") %> <span>/ Night</span>
  </div>

  <!-- Description -->
  <p class="listing-description"><%= listing.description %></p>

  <!-- Action Buttons -->

<%if(currUser && listing.owner && currUser._id.equals(listing.owner._id)){%>
  <div class="action-btns">
    <a href="/listings/<%= listing._id %>/edit" class="btn-edit">✏️ Edit</a>
    <form method="post" action="/listings/<%= listing._id %>?_method=DELETE" style="margin:0;">
      <button class="btn-delete" type="submit">🗑 Delete</button>
    </form>
  </div>
  <%}%>
  <hr style="border-color:#e0e0e0; margin-bottom: 36px;">

  <!-- Leave a Comment -->
    
  <h4 class="section-title">Leave a Review</h4>
<% if(currUser){%>
  <div class="review-form-card">
    <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">

      <div class="mb-3">
        <label for="rating">Rating: <span class="rating-display" id="ratingVal">3</span> / 5</label>
        <input type="range" name="review[rating]" id="rating" min="1" max="5" value="3"
          class="form-range"
          oninput="document.getElementById('ratingVal').textContent = this.value">
      </div>

      <div class="mb-3">
        <label for="comment">Your Comment</label>
        <textarea name="review[comment]" id="comment" rows="4"
          class="form-control" placeholder="Share your experience..." required></textarea>
        <div class="valid-feedback">Thanks for your review!</div>
        <div class="invalid-feedback">Please add a comment.</div>
      </div>

      <button type="submit" class="btn-submit-review">Submit Review</button>
    </form>
  </div>
  <%}%>



  <!-- All Reviews -->
  <% if(listing.reviews.length > 0) { %>
    <h4 class="section-title">All Reviews (<%= listing.reviews.length %>)</h4>
    <div class="reviews-grid">
      <% for(review of listing.reviews) { %>
        <div class="review-card">
          <p class="reviewer-name">👤 <%= review.author.username %></p>
          <p class="review-stars">
            <% for(let i = 0; i < review.rating; i++) { %>★<% } %>
            <% for(let i = review.rating; i < 5; i++) { %>☆<% } %>
            (<%= review.rating %>/5)
          </p>
          <p class="review-comment"><%= review.comment %></p>
          <form method="post" action="/listings/<%= listing.id %>/reviews/<%= review._id %>?_method=DELETE">
            <button class="btn-delete-review" type="submit">🗑 Delete</button>
          </form>
        </div>
      <% } %>
    </div>
  <% } else { %>
    <p style="color:#888; font-style:italic;">No reviews yet. Be the first to review!</p>
  <% } %>

<h3>Where you'll be</h3>
  <div id="map" style="height: 400px; width: 100%; border-radius: 12px; z-index: 1;"></div>

<script>
    const coordinates = JSON.parse('<%- JSON.stringify(listing.geometry && listing.geometry.coordinates ? listing.geometry.coordinates : [72.3693, 23.5880]) %>');
    const listingLocation = "<%= listing.location %>, <%= listing.country %>";
</script>

<script src="/js/map.js"></script>




</div>


































































